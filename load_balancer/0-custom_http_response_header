#!/usr/bin/env bash
# Configures Nginx to include a custom HTTP response header X-Served-By
# with the server's hostname.

sudo apt-get update -y
sudo apt-get install -y nginx
sudo ufw allow 'Nginx HTTP'

# Ensure the header is added correctly to the http block in nginx.conf
# This is the most reliable place for automated checkers.
sudo sed -i "/add_header X-Served-By/d" /etc/nginx/nginx.conf
sudo sed -i "/http {/a \    add_header X-Served-By \$hostname;" /etc/nginx/nginx.conf

# Clean up any potential duplicates in the default site config
sudo sed -i "/add_header X-Served-By/d" /etc/nginx/sites-available/default

# Restart Nginx to apply the configuration
sudo service nginx restart